# --- LLM (server-side only; never exposed to the client bundle) ---
ANTHROPIC_API_KEY=
# Current production default model (verified 2026-07). Pinned snapshot id.
ANTHROPIC_MODEL=claude-sonnet-5

# --- Ingestion ---
# rainforest = third-party scraped-data API (recommended default on
#              reliability grounds; NOT affiliated with or licensed by Amazon)
# firecrawl  = general scraping vendor; same Amazon ToS exposure as scraping
# paste      = operator pastes PDP HTML or fills manual fields; zero automated fetch
INGEST_PROVIDER=rainforest
RAINFOREST_API_KEY=
FIRECRAWL_API_KEY=

# --- Pipeline ---
# Repair budget after the first optimize pass (0–10). Lower = faster, more
# surfaced-but-fixable gate failures. Default 2.
MAX_REPAIR_ITERATIONS=2

# Jul 27 2026 Amazon title policy handling: dual | legacy | new75
# Controls UI ordering + prompt emphasis only; both titles are always
# generated and gated regardless.
TITLE_POLICY=dual

# --- Deployment protection (public URL = real LLM/provider spend) ---
# Optional shared secret required by the API routes. Empty = open (dev only).
APP_ACCESS_TOKEN=
